{
  "name": "booth-mcp",
  "version": "0.2.2",
  "description": "Read-only MCP server for safely querying the BOOTH seller dashboard",
  "type": "module",
  "bin": {
    "booth-mcp": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "files": [
    "dist",
    ".codex-plugin",
    ".mcp.json",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "bun scripts/clean-dist.mjs",
    "build": "bun run clean && bun build src/cli.ts --target=node --format=esm --minify --outfile=dist/cli.js --external=playwright-core && tsc -p tsconfig.build.json",
    "dev": "bun src/cli.ts",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "cross-env BOOTH_MCP_LIVE=1 vitest run tests/live",
    "check:version": "node scripts/sync-version.mjs --check",
    "check:distribution": "bun run check:version && node scripts/validate-distribution.mjs",
    "check:package": "node scripts/check-package-files.mjs",
    "check:package-smoke": "node scripts/smoke-package.mjs",
    "version": "node scripts/sync-version.mjs && git add -- .codex-plugin/plugin.json .mcp.json",
    "prepack": "bun run check:distribution && bun run build"
  },
  "keywords": [
    "booth",
    "mcp",
    "model-context-protocol",
    "pixiv"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cstria0106/booth-mcp.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "cheerio": "1.1.2",
    "playwright-core": "1.61.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@types/node": "25.0.3",
    "cross-env": "10.1.0",
    "eslint": "9.39.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.53.1",
    "vitest": "4.0.18"
  },
  "packageManager": "bun@1.3.14"
}
